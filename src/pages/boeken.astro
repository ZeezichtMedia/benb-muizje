---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/common/Navbar.astro";
import Footer from "../components/common/Footer.astro";
import { useTranslations } from "../i18n/ui";
import { getCollection } from "astro:content";
import AvailabilityCalendar from "../components/booking/AvailabilityCalendar";

const currentLang = "nl";
const t = useTranslations(currentLang);

const pages = await getCollection("site");
const accomPage = pages.find((p) => p.slug === "nl/accommodatie");
const ratesData = accomPage?.data?.rates;
---

<Layout title="Zeeuwse Buurn | Reserveren & Prijzen" lang={currentLang}>
    <Navbar forceOpaque={true} />
    <div class="pt-28 md:pt-36 pb-16 bg-brand-light min-h-screen">
        <div class="max-w-6xl mx-auto px-4 sm:px-6">

            <!-- Compact Header -->
            <div class="text-center max-w-2xl mx-auto mb-10">
                <span class="font-['Caveat'] text-2xl text-brand-accent block mb-1 transform -rotate-1">Transparant & Eerlijk</span>
                <h1 class="text-3xl md:text-4xl font-heading font-black text-brand-dark mb-3">
                    Reserveren <span class="text-brand-green">&</span> Prijzen
                </h1>
                <p class="text-base text-brand-dark/60 leading-relaxed">
                    Bekijk onze tarieven en boek direct uw verblijf aan de Zeeuwse kust.
                </p>
            </div>

            <!-- Combined Rates + Booking Layout -->
            <div class="grid lg:grid-cols-5 gap-8 items-start">

                <!-- LEFT: Rates (3 cols) -->
                {ratesData && (
                <div class="lg:col-span-3 space-y-6">
                    <!-- Price Table Card -->
                    <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-brand-clay/10">
                        <div class="bg-brand-green px-6 py-4 flex items-center justify-between">
                            <h2 class="text-white font-heading font-bold text-lg">{ratesData.title}</h2>
                            <span class="text-white/70 text-sm hidden sm:block">Wekelijks van za 15:00 tot za 10:00</span>
                        </div>
                        <div class="divide-y divide-brand-clay/10">
                            {ratesData.prices.map((price: any) => (
                                <div class="flex items-center justify-between px-6 py-3.5 hover:bg-brand-light/40 transition-colors group">
                                    <div class="flex-1 min-w-0">
                                        <span class="font-medium text-brand-dark text-sm group-hover:text-brand-green transition-colors">{price.period}</span>
                                        {price.notes && <span class="block text-xs text-brand-dark/50 mt-0.5">{price.notes}</span>}
                                    </div>
                                    <span class="font-bold text-brand-dark text-lg ml-4 whitespace-nowrap">{price.weekPrice}</span>
                                </div>
                            ))}
                        </div>
                        {ratesData.subtitle && (
                            <div class="px-6 py-3 bg-brand-accent/5 border-t border-brand-clay/10">
                                <p class="text-xs text-brand-dark/60 italic">{ratesData.subtitle}</p>
                            </div>
                        )}
                    </div>

                    <!-- Includes + Additional Costs (Side by Side) -->
                    <div class="grid sm:grid-cols-2 gap-4">
                        <div class="bg-white rounded-2xl p-5 shadow-md border border-brand-clay/10">
                            <h3 class="font-bold text-brand-dark text-sm mb-3 flex items-center gap-2">
                                <span class="w-5 h-5 rounded-full bg-brand-green/10 flex items-center justify-center">
                                    <svg class="w-3 h-3 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                                </span>
                                Inclusief
                            </h3>
                            <ul class="space-y-1.5">
                                {ratesData.includes.map((item: string) => (
                                    <li class="text-sm text-brand-dark/70 flex items-start gap-2">
                                        <span class="text-brand-green mt-0.5 text-xs">✓</span>
                                        {item}
                                    </li>
                                ))}
                            </ul>
                        </div>
                        <div class="bg-white rounded-2xl p-5 shadow-md border border-brand-clay/10">
                            <h3 class="font-bold text-brand-dark text-sm mb-3 flex items-center gap-2">
                                <span class="w-5 h-5 rounded-full bg-brand-accent/10 flex items-center justify-center">
                                    <svg class="w-3 h-3 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6v12m6-6H6"/></svg>
                                </span>
                                Bijkomende kosten
                            </h3>
                            <ul class="space-y-1.5">
                                {ratesData.additionalCosts.map((cost: any) => (
                                    <li class="text-sm text-brand-dark/70 flex justify-between">
                                        <span>{cost.item}</span>
                                        <span class="font-semibold text-brand-dark">{cost.price}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </div>

                    <!-- Policies Note -->
                    {ratesData.policies && ratesData.policies.length > 0 && (
                        <div class="bg-amber-50/80 rounded-xl px-5 py-3 border border-amber-200/50">
                            <div class="flex items-start gap-2">
                                <svg class="w-4 h-4 text-amber-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                <ul class="space-y-1">
                                    {ratesData.policies.map((policy: string) => (
                                        <li class="text-xs text-amber-900/70">{policy}</li>
                                    ))}
                                </ul>
                            </div>
                        </div>
                    )}
                </div>
                )}

                <!-- RIGHT: Calendar + Form (2 cols) -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- Calendar -->
                    <div class="bg-white rounded-2xl shadow-lg border border-brand-clay/10 p-4 overflow-hidden">
                        <AvailabilityCalendar client:load lang={currentLang} />
                    </div>

                    <!-- Booking Form -->
                    <div id="booking-form-container" class="bg-white rounded-2xl shadow-lg border border-brand-clay/10 p-6 relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-brand-green via-brand-accent to-brand-green"></div>
                        
                        <h2 class="text-xl font-heading font-bold text-brand-dark mb-4 text-center">Uw Reservering</h2>

                        <!-- Date Summary -->
                        <div class="bg-brand-green/5 rounded-xl p-3 mb-5 text-center border border-brand-green/15">
                            <p class="text-brand-dark/50 text-xs font-bold uppercase tracking-wider mb-1">Geselecteerde Periode</p>
                            <p id="date-summary" class="text-lg font-heading font-bold text-brand-green">—</p>
                            <p class="text-[10px] text-brand-dark/40 mt-1 italic">(Kies data in de kalender)</p>
                        </div>

                        <form id="booking-form" class="space-y-3">
                            <input type="hidden" id="checkin" name="checkin" required />
                            <input type="hidden" id="checkout" name="checkout" required />

                            <input type="text" name="name" placeholder={t("form.name")} required
                                class="w-full px-4 py-3 rounded-lg bg-brand-light border-transparent focus:border-brand-green focus:bg-white focus:ring-0 transition-colors text-sm" />
                            
                            <div class="grid grid-cols-2 gap-3">
                                <input type="email" name="email" placeholder={t("form.email")} required
                                    class="w-full px-4 py-3 rounded-lg bg-brand-light border-transparent focus:border-brand-green focus:bg-white focus:ring-0 transition-colors text-sm" />
                                <input type="tel" name="phone" placeholder={t("form.phone")} required
                                    class="w-full px-4 py-3 rounded-lg bg-brand-light border-transparent focus:border-brand-green focus:bg-white focus:ring-0 transition-colors text-sm" />
                            </div>

                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label for="guests" class="block text-xs font-bold text-brand-dark/80 mb-1 pl-1">{t("form.guests")}</label>
                                    <select id="guests" name="guests" class="w-full px-4 py-3 rounded-lg bg-brand-light border-transparent focus:border-brand-green focus:bg-white focus:ring-0 transition-colors text-sm appearance-none">
                                        <option value="1">1</option>
                                        <option value="2" selected>2</option>
                                        <option value="3">3</option>
                                        <option value="4">4</option>
                                    </select>
                                </div>
                                <div>
                                    <label for="age_oldest" class="block text-xs font-bold text-brand-dark/80 mb-1 pl-1">{t("form.age_oldest")}</label>
                                    <input type="number" id="age_oldest" name="age_oldest" min="18" required
                                        class="w-full px-4 py-3 rounded-lg bg-brand-light border-transparent focus:border-brand-green focus:bg-white focus:ring-0 transition-colors text-sm" />
                                </div>
                            </div>

                            <!-- Pet Inline -->
                            <div class="flex items-center justify-between bg-brand-light rounded-lg px-4 py-3">
                                <span class="text-sm font-medium text-brand-dark/80">{t("form.pet")}</span>
                                <div class="flex gap-3">
                                    <label class="flex items-center gap-1.5 cursor-pointer">
                                        <input type="radio" name="pet" value="yes" class="accent-brand-green w-4 h-4" />
                                        <span class="text-sm text-brand-dark/70">{t("form.yes")}</span>
                                    </label>
                                    <label class="flex items-center gap-1.5 cursor-pointer">
                                        <input type="radio" name="pet" value="no" checked class="accent-brand-green w-4 h-4" />
                                        <span class="text-sm text-brand-dark/70">{t("form.no")}</span>
                                    </label>
                                </div>
                            </div>

                            <textarea name="remarks" rows="2" placeholder={t("form.remarks")}
                                class="w-full px-4 py-3 rounded-lg bg-brand-light border-transparent focus:border-brand-green focus:bg-white focus:ring-0 transition-colors text-sm resize-none"></textarea>

                            <p class="text-[11px] text-brand-dark/50 italic text-center">{t("form.disclaimer")}</p>

                            <div id="booking-message" class="hidden rounded-lg p-4 text-center font-bold text-sm"></div>

                            <button type="submit" id="submit-btn"
                                class="w-full bg-brand-green text-white font-bold text-base py-3.5 rounded-full shadow-lg hover:bg-brand-dark hover:scale-[1.02] active:scale-95 transition-all duration-300">
                                {t("form.send")}
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <Footer />
</Layout>

<script define:vars={{ currentLang }}>
    document.addEventListener("DOMContentLoaded", function () {
        const formContainer = document.getElementById("booking-form-container");
        const summaryElement = document.getElementById("date-summary");
        const checkinInput = document.getElementById("checkin");
        const checkoutInput = document.getElementById("checkout");

        function formatDate(dateStr) {
            const date = new Date(dateStr);
            return date.toLocaleDateString(
                currentLang === "nl" ? "nl-NL" : currentLang === "de" ? "de-DE" : "en-US",
                { day: "numeric", month: "short", year: "numeric" },
            );
        }

        window.addEventListener("booking-dates-selected", (e) => {
            const { start, end } = e.detail;
            if (start && end) {
                const startObj = new Date(start);
                const endObj = new Date(end);
                const formatISO = (d) => {
                    const offset = d.getTimezoneOffset();
                    const local = new Date(d.getTime() - offset * 60 * 1000);
                    return local.toISOString().split("T")[0];
                };
                checkinInput.value = formatISO(startObj);
                checkoutInput.value = formatISO(endObj);
                summaryElement.innerText = `${formatDate(start)}  —  ${formatDate(end)}`;
                formContainer.scrollIntoView({ behavior: "smooth", block: "start" });
            }
        });

        const bookingForm = document.getElementById("booking-form");
        const bookingMessage = document.getElementById("booking-message");
        const submitBtn = document.getElementById("submit-btn");

        if (bookingForm) {
            bookingForm.addEventListener("submit", async (e) => {
                e.preventDefault();
                if (!checkinInput.value || !checkoutInput.value) {
                    alert("Selecteer eerst een datum.");
                    return;
                }
                const formData = new FormData(bookingForm);
                const data = Object.fromEntries(formData);
                if (submitBtn) { submitBtn.disabled = true; submitBtn.innerText = "Versturen..."; }
                if (bookingMessage) bookingMessage.classList.add("hidden");
                try {
                    const response = await fetch("/api/reservation", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(data),
                    });
                    if (response.ok) {
                        bookingForm.reset();
                        checkinInput.value = "";
                        checkoutInput.value = "";
                        if (summaryElement) summaryElement.innerText = "—";
                        if (bookingMessage) {
                            bookingMessage.innerText = "Bedankt! Uw aanvraag is verzonden. We nemen spoedig contact met u op.";
                            bookingMessage.className = "rounded-lg p-4 text-center font-bold text-sm bg-green-100 text-green-800 border border-green-200 block";
                        }
                    } else { throw new Error("Submission failed"); }
                } catch (err) {
                    console.error(err);
                    if (bookingMessage) {
                        bookingMessage.innerText = "Er ging iets mis. Probeer het later opnieuw of stuur ons een email.";
                        bookingMessage.className = "rounded-lg p-4 text-center font-bold text-sm bg-red-100 text-red-800 border border-red-200 block";
                    }
                } finally {
                    if (submitBtn) { submitBtn.disabled = false; submitBtn.innerText = "Verstuur"; }
                }
            });
        }
    });
</script>
